[gd_scene load_steps=4 format=3 uid="uid://c8jxq2mhfdt5u"]

[ext_resource type="PackedScene" path="res://scenes/UI/RevenueDisplay.tscn" id="1_revdisp"]
[ext_resource type="PackedScene" path="res://scenes/UI/OrderQueue.tscn"    id="2_oq"]
[ext_resource type="Script"      path="res://scripts/CustomerManager.gd"   id="3_cm"]

; ─────────────────────────────────────────────────────────────────────────────
; Main — full-viewport Control
; Top half  → CafeView  (Node2D, customers live here)
; Bottom half → UIPanel (Control, player interaction)
; Sibling   → CustomerManager (Node, spawn loop)
; ─────────────────────────────────────────────────────────────────────────────

[node name="Main" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2

; ── Top half ──────────────────────────────────────────────────────────────────

[node name="CafeView" type="Node2D" parent="."]

[node name="Background" type="ColorRect" parent="CafeView"]
color = Color(0.961, 0.925, 0.843, 1)
size = Vector2(1080, 960)

; ── Bottom half ───────────────────────────────────────────────────────────────

[node name="UIPanel" type="Control" parent="."]
layout_mode = 1
anchor_top = 0.5
anchor_right = 1.0
anchor_bottom = 1.0
grow_vertical = 1

[node name="Layout" type="VBoxContainer" parent="UIPanel"]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2

; Three station placeholder buttons — warm brown, soft blue, muted yellow

[node name="StationBar" type="HBoxContainer" parent="UIPanel/Layout"]
layout_mode = 2
custom_minimum_size = Vector2(0, 200)
size_flags_horizontal = 3
size_flags_vertical = 3

[node name="Station1" type="ColorRect" parent="UIPanel/Layout/StationBar"]
layout_mode = 2
custom_minimum_size = Vector2(48, 48)
size_flags_horizontal = 3
size_flags_vertical = 3
color = Color(0.831, 0.647, 0.455, 1)

[node name="Station2" type="ColorRect" parent="UIPanel/Layout/StationBar"]
layout_mode = 2
custom_minimum_size = Vector2(48, 48)
size_flags_horizontal = 3
size_flags_vertical = 3
color = Color(0.455, 0.647, 0.831, 1)

[node name="Station3" type="ColorRect" parent="UIPanel/Layout/StationBar"]
layout_mode = 2
custom_minimum_size = Vector2(48, 48)
size_flags_horizontal = 3
size_flags_vertical = 3
color = Color(0.831, 0.773, 0.455, 1)

; Live order queue — replaces the Phase 1 ColorRect placeholder

[node name="OrderQueue" parent="UIPanel/Layout" instance=ExtResource("2_oq")]
layout_mode = 2
size_flags_horizontal = 3
size_flags_vertical = 0

; Revenue display

[node name="RevenueDisplay" parent="UIPanel/Layout" instance=ExtResource("1_revdisp")]
layout_mode = 2
size_flags_horizontal = 3
size_flags_vertical = 3

; ── Spawn manager ─────────────────────────────────────────────────────────────
; unique_name_in_owner lets OrderQueueUI (and future nodes) find this as %CustomerManager

[node name="CustomerManager" type="Node" parent="."]
unique_name_in_owner = true
script = ExtResource("3_cm")
