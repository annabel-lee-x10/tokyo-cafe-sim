[gd_scene load_steps=10 format=3 uid="uid://c8jxq2mhfdt5u"]

[ext_resource type="PackedScene" path="res://scenes/UI/RevenueDisplay.tscn" id="1_revdisp"]
[ext_resource type="PackedScene" path="res://scenes/UI/OrderQueue.tscn"    id="2_oq"]
[ext_resource type="Script"      path="res://scripts/CustomerManager.gd"   id="3_cm"]
[ext_resource type="PackedScene" path="res://scenes/UI/Station.tscn"       id="4_station"]
[ext_resource type="Script"      path="res://scripts/StationManager.gd"    id="5_sm"]
[ext_resource type="PackedScene" path="res://scenes/UI/DayTimer.tscn"      id="6_dt"]
[ext_resource type="PackedScene" path="res://scenes/UI/DialoguePanel.tscn" id="7_dialogue"]
[ext_resource type="PackedScene" path="res://scenes/UI/ToastLayer.tscn"    id="8_toast"]
