; ─────────────────────────────────────────────────────────────────────────────
; UIPanel Layout order (top → bottom) — designed for portrait thumb reach:
;   DayTimer        40px   — day / time status
;   RevenueDisplay  expands
;   OrderQueue      80px
;   StationBar      280px  — bottom quarter of screen
;
; Phase 4 additions at root level:
;   DialoguePanel   — full-screen loyalty scene overlay (visible=false by default)
;   ToastLayer      — CanvasLayer layer=10 for notification toasts
;   RegularSceneQueue — queues dialogue scenes, plays one per day-end
; ─────────────────────────────────────────────────────────────────────────────

[node name="Main" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2

; ── Top half: cafe scene ──────────────────────────────────────────────────────

[node name="CafeView" type="Node2D" parent="."]

[node name="Background" type="ColorRect" parent="CafeView"]
color = Color(0.961, 0.925, 0.843, 1)
size = Vector2(1080, 960)

; ── Bottom half: player UI ────────────────────────────────────────────────────

[node name="UIPanel" type="Control" parent="."]
layout_mode = 1
anchor_top = 0.5
anchor_right = 1.0
anchor_bottom = 1.0
grow_vertical = 1

[node name="Layout" type="VBoxContainer" parent="UIPanel"]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2

[node name="DayTimer" parent="UIPanel/Layout" instance=ExtResource("6_dt")]
layout_mode = 2
size_flags_horizontal = 3
size_flags_vertical = 0

[node name="RevenueDisplay" parent="UIPanel/Layout" instance=ExtResource("1_revdisp")]
layout_mode = 2
size_flags_horizontal = 3
size_flags_vertical = 3

[node name="OrderQueue" parent="UIPanel/Layout" instance=ExtResource("2_oq")]
layout_mode = 2
custom_minimum_size = Vector2(0.0, 80.0)
size_flags_horizontal = 3
size_flags_vertical = 0

[node name="StationBar" type="HBoxContainer" parent="UIPanel/Layout"]
layout_mode = 2
custom_minimum_size = Vector2(0.0, 280.0)
size_flags_horizontal = 3
size_flags_vertical = 0

[node name="Espresso" parent="UIPanel/Layout/StationBar" instance=ExtResource("4_station")]
layout_mode = 2
size_flags_horizontal = 3
size_flags_vertical = 3
station_id = "espresso"

[node name="Drip" parent="UIPanel/Layout/StationBar" instance=ExtResource("4_station")]
layout_mode = 2
size_flags_horizontal = 3
size_flags_vertical = 3
station_id = "drip"

[node name="Matcha" parent="UIPanel/Layout/StationBar" instance=ExtResource("4_station")]
layout_mode = 2
size_flags_horizontal = 3
size_flags_vertical = 3
station_id = "matcha"

; ── Game systems ──────────────────────────────────────────────────────────────

[node name="CustomerManager" type="Node" parent="."]
unique_name_in_owner = true
script = ExtResource("3_cm")

[node name="StationManager" type="Node" parent="."]
script = ExtResource("5_sm")

; ── Phase 4: loyalty scenes + toasts ─────────────────────────────────────────

; Full-screen dialogue overlay — drawn on top of UIPanel; hidden=true by default
[node name="DialoguePanel" parent="." instance=ExtResource("7_dialogue")]

; Toast notification layer — CanvasLayer layer=10, sits above everything
[node name="ToastLayer" parent="." instance=ExtResource("8_toast")]

; Queues loyalty scenes from RegularManager, plays one per day-end
[node name="RegularSceneQueue" type="Node" parent="."]
script = ExtResource("9_rsq")
