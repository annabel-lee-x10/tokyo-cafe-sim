[gd_scene load_steps=2 format=3 uid="uid://bdaytimer01"]

[ext_resource type="Script" path="res://scripts/UI/DayTimerUI.gd" id="1_script"]

; Layout: [Shop] | Day label | Follower count | Time | [Pause]
; Shop button opens the UpgradePanel. Pause button opens the PauseMenu.

[node name="DayTimer" type="HBoxContainer"]
script = ExtResource("1_script")
custom_minimum_size = Vector2(0.0, 40.0)

[node name="UpgradeButton" type="Button" parent="."]
layout_mode = 2
custom_minimum_size = Vector2(110.0, 0.0)
text = "Shop"

[node name="DayLabel" type="Label" parent="."]
layout_mode = 2
size_flags_horizontal = 3
horizontal_alignment = 0
text = "Day 1 / 90"

[node name="FollowerLabel" type="Label" parent="."]
layout_mode = 2
size_flags_horizontal = 3
horizontal_alignment = 1
text = "0 followers"

[node name="TimeLabel" type="Label" parent="."]
layout_mode = 2
size_flags_horizontal = 3
horizontal_alignment = 2
text = "03:00"

[node name="PauseButton" type="Button" parent="."]
layout_mode = 2
custom_minimum_size = Vector2(64.0, 0.0)
text = "||"
