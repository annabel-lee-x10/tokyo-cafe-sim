[gd_scene load_steps=2 format=3 uid="uid://pausemenu01"]

[ext_resource type="Script" path="res://scripts/UI/PauseMenuUI.gd" id="1_script"]

; Pause overlay — Control node drawn on top via sibling order in Main.tscn.
; visible=false by default; opened by ESC or HUD pause button.

[node name="PauseMenu" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_script")
visible = false

; Dark dimming overlay
[node name="Overlay" type="ColorRect" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
color = Color(0.0, 0.0, 0.0, 0.72)

; Centred button panel
[node name="Panel" type="PanelContainer" parent="Overlay"]
layout_mode = 1
anchor_left = 0.15
anchor_top  = 0.30
anchor_right = 0.85
anchor_bottom = 0.72
grow_horizontal = 2
grow_vertical = 2

[node name="VBox" type="VBoxContainer" parent="Overlay/Panel"]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme_override_constants/separation = 12

[node name="PauseLabel" type="Label" parent="Overlay/Panel/VBox"]
layout_mode = 2
size_flags_horizontal = 3
horizontal_alignment = 1
theme_override_font_sizes/font_size = 34
text = "Paused"

[node name="Sep" type="HSeparator" parent="Overlay/Panel/VBox"]
layout_mode = 2

[node name="ResumeBtn" type="Button" parent="Overlay/Panel/VBox"]
layout_mode = 2
