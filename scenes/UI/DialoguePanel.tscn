anchor_bottom = 1.0
grow_vertical = 1

[node name="Content" type="VBoxContainer" parent="Box"]
layout_mode = 2

; Portrait + name row
[node name="TopRow" type="HBoxContainer" parent="Box/Content"]
layout_mode = 2

